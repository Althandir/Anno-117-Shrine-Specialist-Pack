        <Text>
            <Text>Besitze eine ausreichend große und gläubige Bevölkerung auf dieser Insel. (mindestens. 5000 Einwohner & Glauben)</Text>
            <LineId>1600000387</LineId> 
        </Text>
      </ModOp>
    </Group>

